<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/Index.css">
    <style>
        .table-hover tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }
        .card-header {
            background: linear-gradient(135deg, #198754 0%, #20c997 100%);
            color: white;
        }
        .vehiculo-row {
            cursor: pointer;
            transition: all 0.2s;
        }
        .vehiculo-row:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }
        .navbar-custom {
            background-color: #0d6efd;
            box-shadow: 0 2px 4px rgba(0, 0, 0, .1);
        }
        .footer-custom {
            background-color: #343a40;
            color: white;
            padding: 1rem 0;
            margin-top: 2rem;
        }
        .patente-badge {
            background-color: #198754;
            color: white;
            font-family: monospace;
            font-weight: bold;
            letter-spacing: 1px;
        }
        .btn-excel {
            background-color: #1e7e34;
            border-color: #1c6b2b;
            color: white;
        }
        .btn-excel:hover {
            background-color: #15612a;
            border-color: #0f4a20;
            color: white;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-car-front-fill me-2"></i>Gestión Vehicular
            </a>
        </div>
    </nav>
    <main class="container-fluid mt-4">
        <div class="card shadow">
            <div class="card-header">
                <h2><i class="bi bi-truck me-2"></i>Listado de Vehículos</h2>
            </div>
            <div class="card-body">
                <% if (vehiculos.length===0) { %>
                    <div class="text-center">
                        <h4>No hay vehículos</h4>
                    </div>
                    <% } else { %>
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Patente</th>
                                    <th>Marca/Modelo</th>
                                    <th>Año</th>
                                    <th>Tipo</th>
                                    <th>Cliente</th>
                                    <th>Color</th>
                                    <th>Capacidad</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% vehiculos.forEach(vehiculo=> { %>
                                    <tr>
                                        <td>
                                            <%= vehiculo.id_vehiculo %>
                                        </td>
                                        <td>
                                            <span class="badge patente-badge">
                                                <%= vehiculo.patente %>
                                            </span>
                                        </td>
                                        <td>
                                            <strong>
                                                <%= vehiculo.marca %>
                                            </strong><br>
                                            <small>
                                                <%= vehiculo.modelo %>
                                            </small>
                                        </td>
                                        <td>
                                            <%= vehiculo.anio %>
                                        </td>
                                        <td>
                                            <span class="badge bg-info">
                                                <%= vehiculo.nombre_tipo || 'N/A' %>
                                            </span>
                                        </td>
                                        <td>
                                            <strong>
                                                <%= vehiculo.nombre_cliente %>
                                            </strong><br>
                                            <small>
                                                <%= vehiculo.rut_cliente %>
                                            </small>
                                        </td>
                                        <td>
                                            <%= vehiculo.capacidad %>
                                        </td>
                                        <td>
                                            <% if (vehiculo.activo) { %>
                                                <span class="badge bg-success">Activo</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Inactivo</span>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <a href="/vehiculos/eliminar/<%= vehiculo.id_vehiculo %>"
                                                class="btn btn-sm btn-danger btn-eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>

                                    </tr>

                                    <% }); %>
                            </tbody>
                        </table>

                        <% } %>
            </div>
        </div>
    </main>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        $('.btn-eliminar').on('click', function (e) {
            if (!confirm('¿Eliminar vehículo?')) {
                e.preventDefault();
            }
        });
    </script>
</body>
</html>