<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title || 'Sistema de Gestion Vehicular' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/Index.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary-custom shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-car-front-fill me-2"></i>Gestion Vehicular
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarVehicular">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarVehicular">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Inicio</a>
                    </li>

                    <% if (usuario.rol !== 'visualizador') { %>
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownPersonas" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-people me-1"></i>Personas
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownPersonas">
                                <% if (usuario.rol === 'super_admin') { %>
                                    <li><a class="dropdown-item" href="/personas/agregar"><i class="bi bi-person-plus me-2"></i>Agregar Persona</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                <% } %>
                                <li><a class="dropdown-item" href="/personas"><i class="bi bi-list-ul me-2"></i>Listar Personas</a></li>
                            </ul>
                        </li>

                        <% if (usuario.rol === 'super_admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/registro-cambios"><i class="bi bi-shield-check me-1"></i> Auditoría</a>
                            </li>
                        <% } %>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownVehiculos" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-truck me-1"></i>Vehículos
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownVehiculos">
                                <% if (usuario.rol === 'super_admin') { %>
                                    <li><a class="dropdown-item" href="/vehiculos/agregar"><i class="bi bi-plus-circle me-2"></i>Agregar Vehículo</a></li>
                                <% } %>
                                <li><a class="dropdown-item" href="/vehiculos"><i class="bi bi-list-ul me-2"></i>Listar Vehículos</a></li>
                            </ul>
                        </li>
                        <% if (['super_admin', 'admin_cliente'].includes(usuario.rol)) { %>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownGrupos" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-people-fill me-1"></i>Grupos
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdownGrupos">
                                    <% if (usuario.rol === 'super_admin') { %>
                                        <li><a class="dropdown-item" href="/grupos/crear"><i class="bi bi-plus-circle me-2"></i>Crear Grupo</a></li>
                                    <% } %>
                                    <li><a class="dropdown-item" href="/grupos"><i class="bi bi-list-ul me-2"></i>Mis Grupos</a></li>
                                </ul>
                            </li>
                        <% } %>

                        <% if (['super_admin', 'actualizador'].includes(usuario.rol)) { %>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownDocumentos" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-file-earmark-text me-1"></i>Documentos
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdownDocumentos">
                                    <li><h6 class="dropdown-header"><i class="bi bi-truck me-2"></i>Vehículos</h6></li>
                                    <li><a class="dropdown-item" href="/documentos"><i class="bi bi-files me-2"></i>Gestión de Documentos</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header"><i class="bi bi-people me-2"></i>Personas</h6></li>
                                    <li><a class="dropdown-item" href="/documentos-personas"><i class="bi bi-file-earmark-person me-2"></i>Gestión de Documentos</a></li>
                                </ul>
                            </li>
                        <% } %>

                    <% } %> 

                    <% if (typeof usuario !=='undefined' && usuario) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-bold text-white border border-light rounded px-2" href="#" id="navbarUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> <%= usuario.nombre %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarUser">
                                <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</a></li>
                            </ul>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <h1 class="text-center text-primary-custom">Bienvenido al Sistema de Gestión Vehicular</h1>
        <p class="text-center">Plataforma centralizada para el control de vehículos, personas y documentos.</p>

        <% if (usuario.rol !== 'visualizador') { %>
            <div class="quick-actions">
                <h3 class="text-center mb-4"><i class="bi bi-lightning-charge me-2"></i>Acciones Rápidas</h3>
                <div class="row justify-content-center">
                    
                    <% if (usuario.rol === 'super_admin') { %>
                        <div class="col-md-4 mb-3">
                            <div class="card action-card border-primary">
                                <div class="card-body text-center">
                                    <div class="mb-3"><i class="bi bi-person-plus text-primary" style="font-size: 3rem;"></i></div>
                                    <h5 class="card-title">Agregar Persona</h5>
                                    <p class="card-text">Registra una nueva persona en el sistema</p>
                                    <a href="/personas/agregar" class="btn btn-primary-custom"><i class="bi bi-arrow-right me-1"></i>Ir al formulario</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="card action-card border-success">
                                <div class="card-body text-center">
                                    <div class="mb-3"><i class="bi bi-plus-circle text-success" style="font-size: 3rem;"></i></div>
                                    <h5 class="card-title">Agregar Vehículo</h5>
                                    <p class="card-text">Registra un nuevo vehículo en la flota</p>
                                    <a href="/vehiculos/agregar" class="btn btn-success"><i class="bi bi-arrow-right me-1"></i>Ir al formulario</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="card action-card border-dark">
                                <div class="card-body text-center">
                                    <div class="mb-3"><i class="bi bi-clock-history text-dark" style="font-size: 3rem;"></i></div>
                                    <h5 class="card-title">Registro de Cambios</h5>
                                    <p class="card-text">Auditoría del sistema y control de movimientos</p>
                                    <a href="/registro-cambios" class="btn btn-dark"><i class="bi bi-search me-1"></i>Ver historial</a>
                                </div>
                            </div>
                        </div>
                    <% } %>

                    <% if (usuario.rol === 'actualizador') { %>
                        <div class="col-md-4 mb-3">
                            <div class="card action-card border-info">
                                <div class="card-body text-center">
                                    <div class="mb-3"><i class="bi bi-file-earmark-arrow-up text-info" style="font-size: 3rem;"></i></div>
                                    <h5 class="card-title">Subir Documentos</h5>
                                    <p class="card-text">Actualiza la documentación de la flota</p>
                                    <a href="/documentos" class="btn btn-info text-white"><i class="bi bi-arrow-right me-1"></i>Ir a Documentos</a>
                                </div>
                            </div>
                        </div>
                    <% } %>

                </div>
            </div>
        <% } %>

        <div id="carouselVehicular" class="carousel slide rounded shadow overflow-hidden custom-carousel-margin mt-4" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active"><img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70" class="d-block w-100" alt="Flota"></div>
                <div class="carousel-item"><img src="https://images.unsplash.com/photo-1542362567-b07e54358753" class="d-block w-100" alt="Documental"></div>
                <div class="carousel-item"><img src="https://images.unsplash.com/photo-1603386329225-868f9b1ee6c9" class="d-block w-100" alt="Reportes"></div>
            </div>
        </div>
    </main>

    <footer class="footer mt-auto py-3 bg-primary-custom text-white text-center">
        <div class="container">
            <p class="mb-1">&copy; 2026 Sistema de Gestión Vehicular</p>
            <p class="mb-1">
                <i class="bi bi-calendar-check me-1"></i> Fecha del sistema: <span id="fechaActual" class="fw-bold"></span>
            </p>
            <p class="small text-white-50">Control • Seguridad • Reportes</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function actualizarFecha() {
            const fecha = new Date();
            const opciones = {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            };
            const fechaFormateada = fecha.toLocaleString('es-CL', opciones);
            const elementoFecha = document.getElementById("fechaActual");
            if (elementoFecha) {
                elementoFecha.textContent = fechaFormateada;
            }
        }
        actualizarFecha();
        setInterval(actualizarFecha, 1000);
    </script>
</body>
</html>