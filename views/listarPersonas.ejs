<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title || 'Gestión de Personas' %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/Index.css">

    <style>
        :root {
            --primary: #1e3a8a;
            --primary-dark: #172554;
            --gradient: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
        }

        body { background-color: #f4f7f6; }
        .navbar-custom { background: var(--primary); }

        .card-header-custom {
            background: var(--gradient) !important;
            color: #ffffff !important;
            border-bottom: none;
        }
        
        .card-header-custom h3, 
        .card-header-custom small {
            color: #ffffff !important;
        }

        .table-hover tbody tr:hover {
            background: rgba(30, 58, 138, 0.05);
            transition: 0.2s;
        }

        .btn-primary-custom {
            background-color: var(--primary);
            border: none;
            color: white;
        }

        .btn-primary-custom:hover { background-color: var(--primary-dark); color: white; }

        /* Estilo para el footer si no viene en el partial */
        .bg-primary-custom { background: var(--gradient); }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-car me-2"></i> Gestión Vehicular</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/">Inicio</a>
                <a class="nav-link active" href="/personas">Personas</a>
                <a class="nav-link" href="/vehiculos">Vehículos</a>
            </div>
        </div>
    </nav>

    <main class="container-fluid mt-4">
        <div class="card shadow border-0">
            <div class="card-header card-header-custom d-flex justify-content-between align-items-center py-3">
                <div>
                    <h3 class="mb-0 text-white"><i class="fas fa-users me-2"></i> Listado de Personas</h3>
                    <small class="text-white-50">Administración de usuarios y conductores</small>
                </div>
                <div class="d-flex gap-2">
                    <a href="/personas/agregar" class="btn btn-light shadow-sm fw-bold text-primary">
                        <i class="fas fa-user-plus"></i> Agregar Nuevo
                    </a>
                </div>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light text-primary border-bottom">
                            <tr>
                                <th>ID</th>
                                <th>Nombre Completo</th>
                                <th>RUN</th>
                                <th>Contacto</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (personas && personas.length > 0) { %>
                                <% personas.forEach(persona => { %>
                                    <tr class="persona-row">
                                        <td class="fw-bold text-muted"><%= persona.id_persona || persona.id %></td>
                                        <td><%= (persona.nombres || persona.nombre) %> <%= (persona.apellido_paterno || persona.apellido) %></td>
                                        <td><%= persona.run || persona.cedula %></td>
                                        <td>
                                            <div class="small"><i class="fas fa-envelope me-1 text-muted"></i> <%= persona.email %></div>
                                            <% if(persona.telefono) { %>
                                                <div class="small text-muted"><i class="fas fa-phone me-1"></i> <%= persona.telefono %></div>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="badge bg-success-subtle text-success border border-success px-3">Activo</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group shadow-sm">
                                                <button class="btn btn-sm btn-outline-warning" 
                                                        data-bs-toggle="modal" 
                                                        data-bs-target="#modalEditarPersona"
                                                        data-id="<%= persona.id_persona || persona.id %>"
                                                        data-nombre="<%= persona.nombres || persona.nombre %>"
                                                        data-apellido="<%= persona.apellido_paterno || persona.apellido %>"
                                                        data-run="<%= persona.run || persona.cedula %>"
                                                        data-email="<%= persona.email %>"
                                                        data-telefono="<%= persona.telefono || '' %>"
                                                        title="Editar">
                                                    <i class="fas fa-pencil-alt"></i>
                                                </button>
                                                <a href="/personas/eliminar/<%= persona.id_persona || persona.id %>" 
                                                   class="btn btn-sm btn-outline-danger"
                                                   onclick="return confirm('¿Está seguro de eliminar este registro?')">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No hay personas registradas</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div class="modal fade" id="modalEditarPersona" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header card-header-custom">
                    <h5 class="modal-title text-white"><i class="fas fa-user-edit me-2"></i> Editar Datos de Persona</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="formEditarPersona" method="POST">
                    <div class="modal-body p-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Nombres</label>
                                <input type="text" class="form-control shadow-sm" id="edit_nombres" name="nombres" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Apellidos</label>
                                <input type="text" class="form-control shadow-sm" id="edit_apellidos" name="apellidos" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">RUN</label>
                                <input type="text" class="form-control shadow-sm" id="edit_run" name="run" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Teléfono</label>
                                <input type="tel" class="form-control shadow-sm" id="edit_telefono" name="telefono">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">Email</label>
                                <input type="email" class="form-control shadow-sm" id="edit_email" name="email" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary-custom px-4 shadow-sm">Actualizar Registro</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            // Lógica para llenar el modal al abrirse
            const modalEditar = document.getElementById('modalEditarPersona');
            if (modalEditar) {
                modalEditar.addEventListener('show.bs.modal', event => {
                    const button = event.relatedTarget;
                    
                    const id = button.getAttribute('data-id');
                    const nombre = button.getAttribute('data-nombre');
                    const apellido = button.getAttribute('data-apellido');
                    const run = button.getAttribute('data-run');
                    const email = button.getAttribute('data-email');
                    const telefono = button.getAttribute('data-telefono');

                    $('#formEditarPersona').attr('action', `/personas/actualizar/${id}`);
                    $('#edit_nombres').val(nombre);
                    $('#edit_apellidos').val(apellido);
                    $('#edit_run').val(run);
                    $('#edit_email').val(email);
                    $('#edit_telefono').val(telefono);
                });
            }
            // Script para la fecha del sistema en el footer partial
            const fechaSpan = document.getElementById('fechaActual');
            if(fechaSpan) {
                fechaSpan.textContent = new Date().toLocaleDateString();
            }
        });
    </script>
</body>

</html>