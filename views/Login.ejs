<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8">
    <title>
        <%= typeof title !=='undefined' ? title : 'Gestión Vehicular' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/Index.css">
    <link rel="stylesheet" href="/css/Login_Registrer.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg" style="background-color: #172554;">
        <div class="container">
            <a class="navbar-brand text-white" href="/">Gestión Vehicular</a>
        </div>
    </nav>

    <main class="container d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 160px);">
        <div class="card"
            style="max-width: 600px; width: 100%; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
            <div class="card-body p-4">

                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <ul class="nav nav-tabs mb-4" id="authTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="login-tab" data-bs-toggle="tab"
                            data-bs-target="#login" type="button" role="tab">Iniciar Sesión</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="register-tab" data-bs-toggle="tab"
                            data-bs-target="#register" type="button" role="tab">Registrarse</button>
                    </li>
                </ul>

                <div class="tab-content" id="authTabsContent">
                    <div class="tab-pane fade show active" id="login" role="tabpanel">
                        <form method="POST" action="/auth/login">
                            <h2 class="text-center mb-4">Inicio de Sesión</h2>

                            <div class="mb-3">
                                <label for="LoginEmail" class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" id="LoginEmail" name="correo" required>
                            </div>

                            <div class="mb-3">
                                <label for="LoginPassword" class="form-label">Contraseña</label>
                                <input type="password" class="form-control" id="LoginPassword" name="contrasena" required>
                            </div>

                            <button type="submit" class="btn w-100"
                                style="background-color: #172554; color: white; border: none; padding: 10px;">
                                Ingresar
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <button type="button"
                                class="btn border-0 fw-semibold px-3 py-2"
                                data-bs-toggle="modal"
                                data-bs-target="#modalRecuperarPassword"
                                style="color: #172554; background: transparent; text-decoration: none;">
                                <i class="bi bi-key-fill me-2"></i>¿Olvidaste tu contraseña?
                            </button>
                        </div>

                        <div class="text-center mt-3">
                            <a href="/" class="btn btn-secondary">Volver al Inicio</a>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="register" role="tabpanel">
                        <div id="mensajeRegistro"></div>

                        <form id="registerForm">
                            <h2 class="text-center mb-4">Registro de Usuario</h2>

                            <div class="mb-3">
                                <label for="RegisterNombre" class="form-label">Nombre Completo</label>
                                <input type="text" class="form-control" id="RegisterNombre"
                                    name="nombre_completo" required>
                            </div>

                            <div class="mb-3">
                                <label for="RegisterEmail" class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" id="RegisterEmail" name="correo"
                                    required>
                            </div>

                            <div class="mb-3">
                                <label for="RegisterPassword" class="form-label">Contraseña</label>
                                <input type="password" class="form-control" id="RegisterPassword"
                                    name="contrasena" required minlength="6">
                            </div>

                            <div class="mb-4">
                                <label for="RegisterTipo" class="form-label">Tipo de Usuario</label>
                                <select class="form-select" id="RegisterTipo" name="tipo_usuario" required>
                                    <option value="visualizador" selected>Visualizador</option>
                                    <option value="actualizador">Actualizador</option>
                                    <option value="admin_cliente">Admin Cliente</option>
                                    <option value="super_admin">Super Admin</option>
                                </select>
                            </div>

                            <button type="submit" class="btn w-100 mb-3"
                                style="background-color: #059669; color: white; border: none; padding: 10px;">
                                Registrarse
                            </button>

                            <div class="text-center">
                                <a href="/" class="btn btn-secondary">Volver al Inicio</a>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- MODAL RECUPERAR CONTRASEÑA -->
    <div class="modal fade" id="modalRecuperarPassword" tabindex="-1" aria-labelledby="modalRecuperarPasswordLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 18px; overflow: hidden;">
                <div class="modal-header border-0"
                    style="background: linear-gradient(135deg, #172554 0%, #1e3a8a 100%);">
                    <h5 class="modal-title fw-bold text-white" id="modalRecuperarPasswordLabel">
                        <i class="bi bi-shield-lock me-2"></i>Recuperar Contraseña
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Cerrar"></button>
                </div>

                <div class="modal-body p-4" style="background-color: #f8fafc;">
                    <div id="mensajeRecuperacion"></div>

                    <form id="recoverForm">
                        <div class="mb-3">
                            <label for="RecoverEmail" class="form-label fw-semibold text-dark">Correo Electrónico</label>
                            <input type="email" class="form-control form-control-lg"
                                id="RecoverEmail" name="correo" required
                                style="border-radius: 12px; border: 1px solid #d1d5db;">
                        </div>

                        <div class="mb-3">
                            <label for="RecoverPassword" class="form-label fw-semibold text-dark">Nueva Contraseña</label>
                            <input type="password" class="form-control form-control-lg"
                                id="RecoverPassword" name="nueva_contrasena" required minlength="6"
                                style="border-radius: 12px; border: 1px solid #d1d5db;">
                        </div>

                        <div class="mb-3">
                            <label for="RecoverPassword2" class="form-label fw-semibold text-dark">Confirmar Contraseña</label>
                            <input type="password" class="form-control form-control-lg"
                                id="RecoverPassword2" name="confirmar_contrasena" required minlength="6"
                                style="border-radius: 12px; border: 1px solid #d1d5db;">
                        </div>

                        <div class="mb-4">
                            <label for="RecoverTipoUsuario" class="form-label fw-semibold text-dark">Tipo de Usuario</label>
                            <select class="form-select form-select-lg"
                                id="RecoverTipoUsuario" name="tipo_usuario" required
                                style="border-radius: 12px; border: 1px solid #d1d5db;">
                                <option value="visualizador" selected>Visualizador</option>
                                <option value="actualizador">Actualizador</option>
                                <option value="admin_cliente">Admin Cliente</option>
                                <option value="super_admin">Super Admin</option>
                            </select>
                        </div>

                        <button type="submit" class="btn w-100 fw-semibold text-white"
                            style="background: linear-gradient(135deg, #0f9f6e 0%, #059669 100%);
                                   border: none;
                                   border-radius: 12px;
                                   padding: 12px 18px;
                                   font-size: 16px;
                                   box-shadow: 0 6px 18px rgba(5, 150, 105, 0.25);
                                   transition: all 0.25s ease;">
                            <i class="bi bi-arrow-repeat me-2"></i>Cambiar Contraseña
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
  <footer class="footer mt-auto py-3 bg-primary-custom text-white text-center">
    <div class="container">
        <p class="mb-1">&copy; 2026 Sistema de Gestión Vehicular</p>
        <p class="mb-1">
            <i class="bi bi-calendar-check me-1"></i> Fecha del sistema: 
            <span id="fechaActual" class="fw-bold"></span>
        </p>
        <p class="small text-white-50">Control • Seguridad • Reportes</p>
    </div>
</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.mostrarMensaje = function (mensaje, tipo) {
            const mensajeDiv = document.getElementById('mensajeRegistro');
            if (mensajeDiv) {
                mensajeDiv.innerHTML = `
                    <div class="alert alert-${tipo} alert-dismissible fade show" role="alert">
                        ${mensaje}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
            }
        };

        window.mostrarMensajeRecuperacion = function (mensaje, tipo) {
            const mensajeDiv = document.getElementById('mensajeRecuperacion');
            if (mensajeDiv) {
                mensajeDiv.innerHTML = `
                    <div class="alert alert-${tipo} alert-dismissible fade show" role="alert">
                        ${mensaje}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
            }
        };

        document.addEventListener('DOMContentLoaded', function () {
            const registerForm = document.getElementById('registerForm');
            if (registerForm) {
                registerForm.addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const formData = new FormData(registerForm);
                    const data = Object.fromEntries(formData.entries());

                    if (data.contrasena.length < 6) {
                        mostrarMensaje('La contraseña debe tener al menos 6 caracteres.', 'warning');
                        return;
                    }

                    try {
                        mostrarMensaje('Procesando registro...', 'info');

                        const res = await fetch('/auth/register', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });

                        const result = await res.json();

                        if (res.ok) {
                            mostrarMensaje('¡Registro exitoso! Ya puedes iniciar sesión.', 'success');
                            registerForm.reset();
                            setTimeout(() => {
                                const loginTab = new bootstrap.Tab(document.getElementById('login-tab'));
                                loginTab.show();
                            }, 2000);
                        } else {
                            mostrarMensaje(result.error || 'Error en el registro', 'danger');
                        }
                    } catch (err) {
                        console.error(err);
                        mostrarMensaje('Error de conexión con el servidor', 'danger');
                    }
                });
            }

            const recoverForm = document.getElementById('recoverForm');
            if (recoverForm) {
                recoverForm.addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const formData = new FormData(recoverForm);
                    const data = Object.fromEntries(formData.entries());

                    if (!data.correo || !data.nueva_contrasena || !data.confirmar_contrasena || !data.tipo_usuario) {
                        mostrarMensajeRecuperacion('Todos los campos son obligatorios.', 'warning');
                        return;
                    }

                    if (data.nueva_contrasena.length < 6) {
                        mostrarMensajeRecuperacion('La nueva contraseña debe tener al menos 6 caracteres.', 'warning');
                        return;
                    }

                    if (data.nueva_contrasena !== data.confirmar_contrasena) {
                        mostrarMensajeRecuperacion('Las contraseñas no coinciden.', 'warning');
                        return;
                    }

                    try {
                        mostrarMensajeRecuperacion('Actualizando contraseña...', 'info');

                        const res = await fetch('/auth/forgot-password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });

                        const result = await res.json();

                        if (res.ok) {
                            mostrarMensajeRecuperacion(result.success || 'Contraseña actualizada correctamente.', 'success');
                            recoverForm.reset();

                            setTimeout(() => {
                                const modalElement = document.getElementById('modalRecuperarPassword');
                                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                                if (modalInstance) {
                                    modalInstance.hide();
                                }
                            }, 1500);
                        } else {
                            mostrarMensajeRecuperacion(result.error || 'No se pudo actualizar la contraseña.', 'danger');
                        }
                    } catch (err) {
                        console.error(err);
                        mostrarMensajeRecuperacion('Error de conexión con el servidor.', 'danger');
                    }
                });
            }

            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('tab') === 'register') {
                const registerTab = new bootstrap.Tab(document.getElementById('register-tab'));
                registerTab.show();
            }
        });
    </script>
    <script>
    function actualizarFecha() {
        const fecha = new Date();
        const opciones = {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        };
        const fechaFormateada = fecha.toLocaleString('es-CL', opciones);
        const elementoFecha = document.getElementById("fechaActual");

        if (elementoFecha) {
            elementoFecha.textContent = fechaFormateada;
        }
    }

    actualizarFecha();
    setInterval(actualizarFecha, 1000);
</script>
</body>
</html>