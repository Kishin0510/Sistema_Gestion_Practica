<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'Gestión Documental - Personas' %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <style>
        /* Estructura para footer pegado abajo */
        body {
            min-height: 100vh;
            display: flex;
            
        }

        main {
            flex: 1 0 auto;
        }

        .estado-badge {
            font-size: 0.85rem;
            padding: 0.4rem 0.8rem;
        }

        .card-counter {
            transition: transform 0.2s;
            cursor: pointer;
        }

        .card-counter:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

        .table-actions .btn {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
            margin: 0 2px;
        }

        .navbar-custom {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e3a8a 100%);
        }

        #infoPersonaSeleccionada {
            border-left: 4px solid #1e3a8a;
            background-color: #f8f9fa;
            font-size: 0.9rem;
        }

        .required-field::after {
            content: "*";
            color: red;
            margin-left: 4px;
        }
    </style>
</head>

<body class="d-flex flex-column">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/"><i class="fas fa-file-alt me-2"></i>Gestión Documental</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" href="/personas">Personas</a></li>
                        <li class="nav-item"><a class="nav-link active" href="/documentos-persona">Documentos
                                Personas</a></li>
                        <li class="nav-item"><a class="nav-link" href="/vehiculos">Vehículos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/documentos-vehiculo">Docs Vehículos</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main class="container mt-4 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-file-alt me-2 text-primary"></i>Gestión Documental - Personas</h2>
            <div>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoDocumentoPersona">
                    <i class="fas fa-plus me-2"></i>Nuevo Documento
                </button>
                <a href="/personas" class="btn btn-success">
                    <i class="fas fa-users me-2"></i>Gestionar Personas
                </a>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card text-white bg-primary card-counter h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Total Documentos</h6>
                            <h2 class="mb-0">
                                <%= typeof totalDocumentos !=='undefined' ? totalDocumentos : 0 %>
                            </h2>
                        </div>
                        <i class="fas fa-file-alt fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card text-white bg-success card-counter h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Vigentes</h6>
                            <h2 class="mb-0">
                                <%= typeof documentosVigentes !=='undefined' ? documentosVigentes : 0 %>
                            </h2>
                        </div>
                        <i class="fas fa-check-circle fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card text-white bg-warning card-counter h-100">
                    <div class="card-body d-flex justify-content-between align-items-center text-dark">
                        <div>
                            <h6>Por Vencer</h6>
                            <h2 class="mb-0">
                                <%= typeof documentosPorVencer !=='undefined' ? documentosPorVencer : 0 %>
                            </h2>
                        </div>
                        <i class="fas fa-clock fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card text-white bg-danger card-counter h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6>Vencidos</h6>
                            <h2 class="mb-0">
                                <%= typeof documentosVencidos !=='undefined' ? documentosVencidos : 0 %>
                            </h2>
                        </div>
                        <i class="fas fa-exclamation-triangle fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Documentos Registrados</h5>
            </div>
            <div class="card-body">
                <% if (typeof documentos !=='undefined' && documentos.length> 0) { %>
                    <div class="table-responsive">
                        <table id="tablaDocumentos" class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Persona</th>
                                    <th>RUN</th>
                                    <th>Tipo</th>
                                    <th>Número</th>
                                    <th>Vencimiento</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% documentos.forEach(function(doc) { var estadoClass=(doc.estado_calculado==='vencido'
                                    ) ? 'danger' : (doc.estado_calculado==='por_vencer' ? 'warning text-dark'
                                    : 'success' ); %>
                                    <tr>
                                        <td>
                                            <%= doc.id_documento_persona %>
                                        </td>
                                        <td><strong>
                                                <%= doc.persona_nombre_completo %>
                                            </strong></td>
                                        <td>
                                            <%= doc.persona_dni %>
                                        </td>
                                        <td>
                                            <%= doc.tipo_documento_nombre %>
                                        </td>
                                        <td>
                                            <%= doc.numero_documento %>
                                        </td>
                                        <td>
                                            <%= new Date(doc.fecha_vencimiento).toLocaleDateString() %>
                                        </td>
                                        <td><span class="badge bg-<%= estadoClass %> estado-badge">
                                                <%= doc.estado_calculado.toUpperCase() %>
                                            </span></td>
                                        <td class="table-actions">
                                            <button class="btn btn-sm btn-danger btn-eliminar"
                                                data-id="<%= doc.id_documento_persona %>"><i
                                                    class="fas fa-trash"></i></button>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="fas fa-file-invoice fa-4x text-muted mb-3"></i>
                            <h4 class="text-muted">No hay documentos registrados</h4>
                        </div>
                        <% } %>
            </div>
        </div>
    </main>
    <div class="modal fade" id="modalNuevoDocumentoPersona" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Nuevo Documento de Persona</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/documentos-persona/registrar" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold required-field">Persona</label>
                            <select class="form-select" name="id_persona" id="id_persona" required>
                                <option value="">Seleccione una persona...</option>
                                <% if (typeof personas !=='undefined' && personas.length> 0) { %>
                                    <% for(var i=0; i < personas.length; i++) { %>
                                        <option value="<%= personas[i].id_persona %>"
                                            data-run="<%= personas[i].run_completo %>"
                                            data-cargo="<%= personas[i].cargo || '' %>">
                                            <%= personas[i].nombre_completo %> - [<%= personas[i].run_completo %>]
                                        </option>
                                        <% } %>
                                            <% } %>
                            </select>
                            <div id="infoPersonaSeleccionada" class="mt-2 p-2 bg-light rounded d-none">
                                <small id="runPersona" class="me-3 fw-bold"></small>
                                <small id="cargoPersona" class="text-muted"></small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold required-field">Tipo de Documento</label>
                            <input type="text" class="form-control" name="tipo_documento_nombre" list="sugerenciasTipo"
                                placeholder="Ej: Licencia, Contrato" required>
                            <datalist id="sugerenciasTipo">
                                <option value="Licencia de Conducir">
                                <option value="Cédula de Identidad">
                                <option value="Contrato de Trabajo">
                                <option value="Certificado de Antecedentes">
                            </datalist>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold required-field">Número de Documento</label>
                            <input type="text" class="form-control" name="numero_documento" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3"><label class="form-label">Emisión</label><input type="date"
                                    class="form-control" name="fecha_emision"></div>
                            <div class="col-md-6 mb-3"><label
                                    class="form-label fw-bold required-field">Vencimiento</label><input type="date"
                                    class="form-control" name="fecha_vencimiento" required></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Archivo</label>
                            <input type="file" class="form-control" name="archivo" id="archivo_documento"
                                accept=".pdf,.jpg,.jpeg,.png">
                            <div id="previewArchivo" class="mt-2 d-none">
                                <div class="alert alert-info p-2 d-flex justify-content-between align-items-center">
                                    <span id="nombreArchivo"></span>
                                    <button type="button" class="btn-close" id="quitarArchivo"></button>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Observaciones</label>
                            <textarea class="form-control" name="observaciones" rows="2"></textarea>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="enviar_alerta" id="enviarAlerta"
                                checked>
                            <label class="form-check-label" for="enviarAlerta">Enviar alerta por correo</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar Documento</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <footer class="mt-auto text-center text-white py-4" style="background-color: #1e3a8a;">
        <div class="container">
            <p class="mb-1">&copy; 2026 Sistema de Gestión Vehicular</p>
            <p class="small mb-1">Control • Seguridad • Reportes</p>
        </div>
    </footer>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            if ($('#tablaDocumentos').length) {
                $('#tablaDocumentos').DataTable({
                    language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                    order: [[0, 'desc']]
                });
            }

            // Al seleccionar persona, mostrar sus datos dinámicos
            $('#id_persona').on('change', function () {
                const sel = $(this).find(':selected');
                if (sel.val()) {
                    $('#runPersona').text('RUN: ' + sel.data('run'));
                    $('#cargoPersona').text('Cargo: ' + (sel.data('cargo') || 'N/A'));
                    $('#infoPersonaSeleccionada').removeClass('d-none');
                } else {
                    $('#infoPersonaSeleccionada').addClass('d-none');
                }
            });

            // Preview archivo
            $('#archivo_documento').on('change', function () {
                if (this.files && this.files[0]) {
                    $('#nombreArchivo').text(this.files[0].name);
                    $('#previewArchivo').removeClass('d-none');
                }
            });

            $('#quitarArchivo').on('click', function () {
                $('#archivo_documento').val('');
                $('#previewArchivo').addClass('d-none');
            });

            // Eliminar con SweetAlert
            $('.btn-eliminar').on('click', function () {
                const id = $(this).data('id');
                Swal.fire({
                    title: '¿Estás seguro?', text: "Se eliminará permanentemente",
                    icon: 'warning', showCancelButton: true, confirmButtonText: 'Sí, eliminar'
                }).then((res) => {
                    if (res.isConfirmed) {
                        fetch('/documentos-persona/eliminar/' + id, { method: 'DELETE' })
                            .then(r => r.json())
                            .then(d => d.success ? location.reload() : Swal.fire('Error', d.error, 'error'));
                    }
                });
            });
        });
    </script>
</body>

</html>