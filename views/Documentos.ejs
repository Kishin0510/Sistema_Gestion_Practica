<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'Gestión Documental' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="../public/css/Index.css">
    <style>
        :root {
            --primary: #1e3a8a;
            --primary-dark: #172554;
        }
        html,
        body {
            height: 100%;
            margin: 0;
        }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .content-wrapper {
            flex: 1 0 auto;
        }
        .bg-primary {
            background-color: var(--primary) !important;
        }
        .btn-primary {
            background-color: var(--primary);
            border-color: var(--primary);
        }
        .btn-primary:hover {
            background-color: var(--primary-dark);
            border-color: var(--primary-dark);
        }
        .text-primary {
            color: var(--primary) !important;
        }
        .border-primary {
            border-color: var(--primary) !important;
        }
        .card-header.bg-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
        }
        .modal-header.bg-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
        }
        footer {
            flex-shrink: 0;
            width: 100%;
            background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%) !important;
            margin-top: auto;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-car me-2"></i>Gestión Vehicular
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/vehiculos">Vehículos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/documentos">Documentos</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="content-wrapper">
        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-file-alt me-2" style="color: var(--primary);"></i>Gestión Documental</h2>
                <div>
                    <button class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#modalNuevaMantencion">
                        <i class="fas fa-tools me-2"></i>Nueva Mantención
                    </button>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoDocumento">
                        <i class="fas fa-plus me-2"></i>Nuevo Documento
                    </button>
                </div>
            </div>
            <% if (typeof success_msg !=='undefined' && success_msg) { %>
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>
                    <%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <% } %>
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card text-white bg-primary">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Total Documentos</h5>
                                    <h2>
                                        <%= totalDocumentos || 0 %>
                                    </h2>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-white bg-success">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Vigentes</h5>
                                    <h2>
                                        <%= documentosVigentes || 0 %>
                                    </h2>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-white bg-warning">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Por Vencer</h5>
                                    <h2>
                                        <%= documentosPorVencer || 0 %>
                                    </h2>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-white bg-danger">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Vencidos</h5>
                                    <h2>
                                        <%= documentosVencidos || 0 %>
                                    </h2>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-list me-2"></i>Documentos Registrados</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table id="tablaDocumentos" class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Vehículo</th>
                                            <th>Tipo</th>
                                            <th>Número</th>
                                            <th>Vencimiento</th>
                                            <th>Estado</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (documentos && documentos.length> 0) { %>
                                            <% for(var i=0; i < documentos.length; i++) { var doc=documentos[i]; var
                                                fechaVenc=new Date(doc.fecha_vencimiento); var hoy=new Date(); var
                                                diffDays=Math.ceil((fechaVenc - hoy) / (1000 * 60 * 60 * 24)); var
                                                estadoClass='success' ; var estadoTexto='Vigente' ; if (diffDays <=0) {
                                                estadoClass='danger' ; estadoTexto='Vencido' ; } else if (diffDays <=7)
                                                { estadoClass='danger' ; estadoTexto='⏳ Urgente' ; } else if (diffDays
                                                <=30) { estadoClass='warning' ; estadoTexto='⏳ Por vencer' ; } %>
                                                <tr>
                                                    <td>
                                                        <%= doc.id_documento_veh %>
                                                    </td>
                                                    <td><strong>
                                                            <%= doc.patente || 'N/A' %>
                                                        </strong><br><small>
                                                            <%= doc.marca || '' %>
                                                                <%= doc.modelo || '' %>
                                                        </small></td>
                                                    <td>
                                                        <%= doc.tipo_documento_nombre %>
                                                    </td>
                                                    <td>
                                                        <%= doc.numero_documento %>
                                                    </td>
                                                    <td>
                                                        <%= fechaVenc.toLocaleDateString() %>
                                                    </td>
                                                    <td><span class="badge bg-<%= estadoClass %>">
                                                            <%= estadoTexto %>
                                                        </span></td>
                                                    <td>
                                                        <button class="btn btn-sm btn-info ver-documento"
                                                            data-id="<%= doc.id_documento_veh %>"><i
                                                                class="fas fa-eye"></i></button>
                                                        <% if (doc.ruta_archivo) { %>
                                                            <a href="<%= doc.ruta_archivo %>"
                                                                class="btn btn-sm btn-success" target="_blank"><i
                                                                    class="fas fa-file-pdf"></i></a>
                                                            <% } %>
                                                    </td>
                                                </tr>
                                                <% } %>
                                                    <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><i class="fas fa-tools me-2"></i>Historial de Mantenciones</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table id="tablaMantenciones" class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Vehículo</th>
                                            <th>Tipo Servicio</th>
                                            <th>Kilometraje</th>
                                            <th>Fecha</th>
                                            <th>Costo</th>
                                            <th>Taller</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (typeof mantenciones !=='undefined' && mantenciones.length> 0) { %>
                                            <% for(var k=0; k < mantenciones.length; k++) { var m=mantenciones[k]; %>
                                                <tr>
                                                    <td><strong>
                                                            <%= m.patente %>
                                                        </strong></td>
                                                    <td>
                                                        <%= m.tipo_mantencion %>
                                                    </td>
                                                    <td>
                                                        <%= m.kilometraje.toLocaleString() %> km
                                                    </td>
                                                    <td>
                                                        <%= new Date(m.fecha_mantencion).toLocaleDateString() %>
                                                    </td>
                                                    <td>$<%= m.costo.toLocaleString() %>
                                                    </td>
                                                    <td>
                                                        <%= m.taller || 'N/A' %>
                                                    </td>
                                                    <td>
                                                        <button class="btn btn-sm btn-warning editar-mantencion"
                                                            data-id="<%= m.id_mantencion %>"><i
                                                                class="fas fa-edit"></i></button>
                                                        <button class="btn btn-sm btn-danger eliminar-mantencion"
                                                            data-id="<%= m.id_mantencion %>"><i
                                                                class="fas fa-trash"></i></button>
                                                        <% if (m.ruta_archivo) { %>
                                                            <a href="<%= m.ruta_archivo %>"
                                                                class="btn btn-sm btn-outline-secondary"
                                                                target="_blank"><i class="fas fa-paperclip"></i></a>
                                                            <% } %>
                                                    </td>
                                                </tr>
                                                <% } %>
                                                    <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
        </div>
    </div>
    <div class="modal fade" id="modalNuevaMantencion" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Registrar Mantención</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/mantenciones/registrar" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Vehículo <span class="text-danger">*</span></label>
                                <select class="form-select" name="id_vehiculo" required>
                                    <option value="">Seleccione un vehículo...</option>
                                    <% if (vehiculos && vehiculos.length> 0) { %>
                                        <% for(var j=0; j < vehiculos.length; j++) { var v=vehiculos[j]; %>
                                            <option value="<%= v.id_vehiculo %>">
                                                <%= v.patente %> - <%= v.marca %>
                                                        <%= v.modelo %>
                                            </option>
                                            <% } %>
                                                <% } %>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Tipo de Mantención</label>
                                <input type="text" class="form-control" name="tipo_mantencion"
                                    placeholder="Ej: Cambio de aceite" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Kilometraje <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" name="kilometraje" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Fecha Servicio <span
                                        class="text-danger">*</span></label>
                                <input type="date" class="form-control" name="fecha_mantencion" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Costo Total</label>
                                <input type="number" step="0.01" class="form-control" name="costo">
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Taller / Proveedor</label>
                                <input type="text" class="form-control" name="taller">
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Archivo Respaldo (Opcional)</label>
                                <input type="file" class="form-control" name="archivo_mantencion">
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Observaciones</label>
                                <textarea class="form-control" name="observaciones" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-success">Guardar Mantención</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="modal fade" id="modalEditarMantencion" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Editar Mantención</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="formEditarMantencion" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <input type="hidden" name="id_mantencion" id="edit_m_id">
                        <div class="row" id="edit_m_body">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-warning">Actualizar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="modal fade" id="modalNuevoDocumento" tabindex="-1">...</div>
    <div class="modal fade" id="modalEditarDocumento" tabindex="-1">...</div>
    <footer class="text-center text-white py-4">
        <div class="container">
            <p class="mb-1">&copy; 2026 Sistema de Gestión Vehicular</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            
            $('#tablaDocumentos').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                order: [[4, 'asc']]
            });
            $('#tablaMantenciones').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                order: [[3, 'desc']]
            });
            $('.editar-mantencion').on('click', function () {
                const id = $(this).data('id');
                $('#edit_m_id').val(id);
                $('#formEditarMantencion').attr('action', `/mantenciones/actualizar/${id}`);
                $('#modalEditarMantencion').modal('show');
            });
            $('.eliminar-mantencion').on('click', function () {
                const id = $(this).data('id');
                if (confirm('¿Estás seguro de eliminar este registro de mantención? Esta acción no se puede deshacer.')) {
                    window.location.href = `/mantenciones/eliminar/${id}`;
                }
            });
        });
    </script>
</body>

</html>