<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'Gestión Documental - Personas' %>
    </title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="/css/Index.css">

    <style>
        .estado-badge {
            font-size: 0.85rem;
            padding: 0.4rem 0.8rem;
        }

        .card-counter {
            transition: transform 0.2s;
        }

        .card-counter:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

        .table-actions .btn {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
        }

        .documento-vencido {
            background-color: rgba(220, 53, 69, 0.05);
        }

        .documento-urgente {
            background-color: rgba(255, 193, 7, 0.05);
        }

        .navbar-custom {
            background: #0d6efd;
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-file-alt me-2"></i>Gestión Documental
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/personas">
                            <i class="fas fa-users me-1"></i>Personas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/documentos-persona">
                            <i class="fas fa-file-alt me-1"></i>Documentos Personas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/vehiculos">
                            <i class="fas fa-truck me-1"></i>Vehículos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/documentos-vehiculo">
                            <i class="fas fa-file-pdf me-1"></i>Docs Vehículos
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-file-alt me-2 text-primary"></i>Gestión Documental - Personas</h2>
            <div>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoDocumento">
                    <i class="fas fa-plus me-2"></i>Nuevo Documento
                </button>
                <a href="/personas" class="btn btn-success">
                    <i class="fas fa-users me-2"></i>Gestionar Personas
                </a>
            </div>
        </div>

        <!-- Mensajes Flash -->
        <% if (typeof success_msg !=='undefined' && success_msg) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                <%= success_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

                <% if (typeof error_msg !=='undefined' && error_msg) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <%= error_msg %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                        <!-- Tarjetas de resumen -->
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="card text-white bg-primary card-counter">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="card-title mb-1">Total Documentos</h6>
                                                <h2 class="mb-0">
                                                    <%= typeof totalDocumentos !=='undefined' ? totalDocumentos : 0 %>
                                                </h2>
                                            </div>
                                            <i class="fas fa-file-alt fa-3x opacity-50"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-white bg-success card-counter">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="card-title mb-1">Vigentes</h6>
                                                <h2 class="mb-0">
                                                    <%= typeof documentosVigentes !=='undefined' ? documentosVigentes :
                                                        0 %>
                                                </h2>
                                            </div>
                                            <i class="fas fa-check-circle fa-3x opacity-50"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-white bg-warning card-counter">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="card-title mb-1">Por Vencer</h6>
                                                <h2 class="mb-0">
                                                    <%= typeof documentosPorVencer !=='undefined' ? documentosPorVencer
                                                        : 0 %>
                                                </h2>
                                            </div>
                                            <i class="fas fa-clock fa-3x opacity-50"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-white bg-danger card-counter">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="card-title mb-1">Vencidos</h6>
                                                <h2 class="mb-0">
                                                    <%= typeof documentosVencidos !=='undefined' ? documentosVencidos :
                                                        0 %>
                                                </h2>
                                            </div>
                                            <i class="fas fa-exclamation-triangle fa-3x opacity-50"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Tabla de documentos -->
                        <div class="card shadow-sm">
                            <div class="card-header bg-primary text-white py-3">
                                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Documentos Registrados</h5>
                            </div>
                            <div class="card-body">
                                <% if (typeof documentos !=='undefined' && documentos && documentos.length> 0) { %>
                                    <div class="table-responsive">
                                        <table id="tablaDocumentos" class="table table-striped table-hover">
                                            <thead>
                                                <tr>
                                                    <th>ID</th>
                                                    <th>Persona</th>
                                                    <th>RUN</th>
                                                    <th>Tipo Documento</th>
                                                    <th>N° Documento</th>
                                                    <th>Vencimiento</th>
                                                    <th>Estado</th>
                                                    <th>Archivo</th>
                                                    <th>Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% documentos.forEach(function(doc) { const fechaVenc=new
                                                    Date(doc.fecha_vencimiento); const hoy=new Date(); const
                                                    diffTime=fechaVenc - hoy; const diffDays=Math.ceil(diffTime / (1000
                                                    * 60 * 60 * 24)); let estadoClass='success' ; let
                                                    estadoTexto='Vigente' ; if (diffDays <=0) { estadoClass='danger' ;
                                                    estadoTexto='Vencido' ; } else if (diffDays <=7) {
                                                    estadoClass='danger' ; estadoTexto='Urgente' ; } else if (diffDays
                                                    <=30) { estadoClass='warning' ; estadoTexto='Por vencer' ; } %>
                                                    <tr
                                                        class="<%= diffDays <= 0 ? 'documento-vencido' : (diffDays <= 7 ? 'documento-urgente' : '') %>">
                                                        <td>
                                                            <%= doc.id_documento %>
                                                        </td>
                                                        <td>
                                                            <strong>
                                                                <%= doc.persona_nombre_completo || 'N/A' %>
                                                            </strong>
                                                            <% if (doc.cargo) { %>
                                                                <br><small class="text-muted">
                                                                    <%= doc.cargo %>
                                                                </small>
                                                                <% } %>
                                                        </td>
                                                        <td>
                                                            <%= doc.persona_dni || 'N/A' %>
                                                        </td>
                                                        <td>
                                                            <%= doc.tipo_documento_nombre || 'Sin tipo' %>
                                                        </td>
                                                        <td>
                                                            <%= doc.numero_documento || 'N/A' %>
                                                        </td>
                                                        <td>
                                                            <%= new Date(doc.fecha_vencimiento).toLocaleDateString() %>
                                                                <br>
                                                                <small
                                                                    class="<%= diffDays <= 0 ? 'text-danger' : (diffDays <= 7 ? 'text-warning' : 'text-muted') %>">
                                                                    <%= diffDays> 0 ? diffDays + ' días' : 'Vencido' %>
                                                                </small>
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-<%= estadoClass %> estado-badge">
                                                                <%= estadoTexto %>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <% if (doc.ruta_archivo) { %>
                                                                <a href="<%= doc.ruta_archivo %>"
                                                                    class="btn btn-sm btn-success" target="_blank"
                                                                    title="Ver archivo">
                                                                    <i class="fas fa-file-pdf"></i>
                                                                </a>
                                                                <% } else { %>
                                                                    <span class="badge bg-secondary">Sin archivo</span>
                                                                    <% } %>
                                                        </td>
                                                        <td class="table-actions">
                                                            <a href="/documentos-persona/detalle/<%= doc.id_documento %>"
                                                                class="btn btn-sm btn-info" title="Ver detalle">
                                                                <i class="fas fa-eye"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                    <% } else { %>
                                        <div class="text-center py-5">
                                            <i class="fas fa-file-alt fa-4x text-muted mb-3"></i>
                                            <h4 class="text-muted">No hay documentos registrados</h4>
                                            <p>Comienza agregando tu primer documento de persona</p>
                                            <button class="btn btn-primary" data-bs-toggle="modal"
                                                data-bs-target="#modalNuevoDocumento">
                                                <i class="fas fa-plus me-2"></i>Agregar Documento
                                            </button>
                                        </div>
                                        <% } %>
                            </div>
                        </div>
    </div>
    <!-- Modal Nuevo Documento -->
    <div class="modal fade" id="modalNuevoDocumento" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Nuevo Documento de Persona</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/documentos-persona/registrar" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <!-- SELECCIÓN DE PERSONA -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Persona <span class="text-danger">*</span></label>
                            <select class="form-select" name="id_persona" required>
                                <option value="">Seleccione una persona...</option>
                                <% if (typeof personas !=='undefined' && personas && personas.length> 0) { %>
                                    <% personas.forEach(function(p) { %>
                                        <option value="<%= p.id_persona %>">
                                            <%= p.apellido_paterno %>, <%= p.nombres %> - <%= p.run %>-<%= p.dv %>
                                                            <% if (p.cargo) { %> [<%= p.cargo %>] <% } %>
                                        </option>
                                        <% }); %>
                                            <% } else { %>
                                                <option value="" disabled>No hay personas registradas</option>
                                                <% } %>
                            </select>
                            <% if (typeof personas==='undefined' || !personas || personas.length===0) { %>
                                <div class="alert alert-warning mt-2">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    No hay personas registradas.
                                    <a href="/personas" class="alert-link">Ir a gestionar personas</a>
                                </div>
                                <% } %>
                        </div>

                        <!-- TIPO DE DOCUMENTO -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tipo de Documento <span
                                    class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="tipo_documento_nombre"
                                placeholder="Ej: Certificado de Antecedentes, Título Profesional, etc."
                                value="Documento Personal" required>
                            <div class="form-text">Se creará automáticamente si no existe</div>
                        </div>

                        <!-- NÚMERO DE DOCUMENTO -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Número de Documento <span
                                    class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="numero_documento"
                                placeholder="Ej: 12345678-9, CERT-2025-001" required>
                        </div>

                        <!-- FECHAS -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Fecha de Emisión</label>
                                <input type="date" class="form-control" name="fecha_emision">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Fecha de Vencimiento <span
                                        class="text-danger">*</span></label>
                                <input type="date" class="form-control" name="fecha_vencimiento" required>
                            </div>
                        </div>

                        <!-- ARCHIVO -->
                        <div class="mb-3">
                            <label class="form-label">Archivo (opcional)</label>
                            <input type="file" class="form-control" name="archivo_documento"
                                accept=".pdf,.jpg,.jpeg,.png">
                            <div class="form-text">PDF, JPG, PNG (Máx. 10MB)</div>
                        </div>

                        <!-- OBSERVACIONES -->
                        <div class="mb-3">
                            <label class="form-label">Observaciones</label>
                            <textarea class="form-control" name="observaciones" rows="2"></textarea>
                        </div>

                        <!-- CHECKBOX ALERTA -->
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="enviar_alerta" id="enviarAlerta"
                                checked>
                            <label class="form-check-label" for="enviarAlerta">
                                Enviar alerta por correo
                            </label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar Documento</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Inicializar DataTable
            if ($('#tablaDocumentos').length) {
                $('#tablaDocumentos').DataTable({
                    language: {
                        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                    },
                    order: [[5, 'asc']],
                    pageLength: 25
                });
            }
        });

        function eliminarDocumento(id) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Esta acción no se puede revertir",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/documentos-persona/eliminar/' + id,
                        method: 'DELETE',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Eliminado',
                                    text: response.message,
                                    timer: 1500
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: response.error || 'Error al eliminar'
                                });
                            }
                        },
                        error: function (xhr) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: xhr.responseJSON?.error || 'No se pudo eliminar el documento'
                            });
                        }
                    });
                }
            });
        }
    </script>
</body>
</html>