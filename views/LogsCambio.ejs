<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'Registro de Actividad' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

    <style>
        :root {
            --primary: #1e3a8a;
            --primary-dark: #172554;
        }

        .bg-primary {
            background-color: var(--primary) !important;
        }

        .text-primary {
            color: var(--primary) !important;
        }

        .card-header.bg-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
        }

        .badge-op {
            width: 85px;
            display: inline-block;
        }

        pre {
            background: #f4f4f4;
            padding: 10px;
            border-radius: 5px;
            font-size: 0.85em;
            max-height: 200px;
            overflow-y: auto;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-car me-2"></i>Gestión Vehicular</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/vehiculos">Vehículos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/documentos">Documentos</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/registro-cambios">Auditoría</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-history me-2" style="color: var(--primary);"></i>Registro de Cambios</h2>
            <button class="btn btn-outline-primary" onclick="window.location.reload()">
                <i class="fas fa-sync-alt me-2"></i>Actualizar
            </button>
        </div>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle me-2"></i>
                <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-clipboard-list me-2"></i>Historial del Sistema</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="tablaLogs" class="table table-striped table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Fecha y Hora</th>
                                        <th>Usuario</th>
                                        <th>Operación</th>
                                        <th>Tabla</th>
                                        <th>ID Ref.</th>
                                        <th>Actividad</th>
                                        <th class="text-center">Detalle</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% logs.forEach(log=> {
                                        let badgeClass = 'bg-secondary';
                                        if(log.operacion === 'INSERT') badgeClass = 'bg-success';
                                        if(log.operacion === 'UPDATE') badgeClass = 'bg-warning text-dark';
                                        if(log.operacion === 'DELETE') badgeClass = 'bg-danger';
                                        %>
                                        <tr>
                                            <td class="small">
                                                <%= log.fecha_formateada %>
                                            </td>
                                            <td>
                                                <strong>
                                                    <%= log.usuario_nombre %>
                                                </strong><br>
                                                <small class="text-muted">
                                                    <%= log.nombre_cliente %>
                                                </small>
                                            </td>
                                            <td>
                                                <span class="badge <%= badgeClass %> badge-op">
                                                    <%= log.operacion %>
                                                </span>
                                            </td>
                                            <td><code><%= log.tabla_afectada %></code></td>
                                            <td>#<%= log.id_registro_afectado %>
                                            </td>
                                            <td>
                                                <%= log.actividad %>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-info text-white btn-detalle"
                                                    data-id="<%= log.id_log %>">
                                                    <i class="fas fa-search-plus"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
    </div>

    <div class="modal fade" id="modalLog" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-info-circle me-2"></i>Detalle del Cambio</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="logContent">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="fw-bold">IP Origen:</label>
                                <p id="logIp" class="text-muted"></p>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold">Tabla:</label>
                                <p id="logTabla" class="badge bg-dark"></p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label class="fw-bold text-danger">Datos Anteriores:</label>
                                <pre id="logPrev"></pre>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold text-success">Datos Nuevos:</label>
                                <pre id="logNew"></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#tablaLogs').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                order: [[0, 'desc']],
                pageLength: 15
            });

            $('.btn-detalle').on('click', function () {
                const id = $(this).data('id');
                fetch(`/registro-cambios/detalle/${id}`) // Ajusta según tu ruta real
                    .then(res => res.json())
                    .then(data => {
                        if (data.error) return alert(data.error);

                        $('#logIp').text(data.ip_origen || 'N/A');
                        $('#logTabla').text(data.tabla_afectada);

                        // Formatear JSON para lectura fácil
                        $('#logPrev').text(JSON.stringify(JSON.parse(data.datos_anteriores || '{}'), null, 2));
                        $('#logNew').text(JSON.stringify(JSON.parse(data.datos_nuevos || '{}'), null, 2));

                        new bootstrap.Modal('#modalLog').show();
                    })
                    .catch(err => console.error(err));
            });
        });
    </script>
</body>

</html>