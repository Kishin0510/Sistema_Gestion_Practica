<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/Index.css">

    <style>
        .table-hover tbody tr:hover {
            background: rgba(13, 110, 253, .05)
        }

        .card-header {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff
        }

        .persona-row {
            transition: .2s
        }

        .persona-row:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, .1)
        }

        .navbar-custom {
            background: #0d6efd
        }

        .footer-custom {
            background: #343a40;
            color: white;
            padding: 1rem;
            margin-top: 2rem
        }

        .btn-excel {
            background: #198754;
            color: white;
            border: none;
            padding: 0.375rem 0.75rem;
            border-radius: 0.375rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .btn-excel:hover {
            background: #146c43;
            color: white;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="bi bi-car-front-fill"></i> Gestión Vehicular</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/">Inicio</a>
                <a class="nav-link active" href="/personas">Personas</a>
                <a class="nav-link" href="/vehiculos">Vehículos</a>
                <a class="nav-link" href="/login">Login</a>
            </div>
        </div>
    </nav>
    <main class="container-fluid mt-4">
        <div class="card shadow mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h3><i class="bi bi-people"></i> Listado de Personas</h3>
                    <small>Gestión completa</small>
                </div>
                <div class="d-flex gap-2">
                    <a href="/personas/exportar-excel" class="btn-excel" id="btnExportarExcel">
                        <i class="bi bi-file-excel"></i> Descargar Lista Excel
                    </a>
                    <a href="/personas/agregar" class="btn btn-light">
                        <i class="bi bi-person-plus"></i> Agregar
                    </a>
                </div>
            </div>

            <div class="card-body">

                <!-- FILTROS -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <input class="form-control" id="filtroNombre" placeholder="Nombre / Apellido">
                    </div>

                    <div class="col-md-3">
                        <input class="form-control" id="filtroRun" placeholder="RUN">
                    </div>

                    <div class="col-md-3">
                        <input class="form-control" id="filtroEmail" placeholder="Email">
                    </div>

                    <div class="col-md-3">
                        <select class="form-select" id="filtroEstado">
                            <option value="">Todos los estados</option>
                            <option value="activo">Activo</option>
                            <option value="inactivo">Inactivo</option>
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-12">
                        <button class="btn btn-outline-secondary btn-sm" id="limpiarFiltros">
                            <i class="bi bi-eraser"></i> Limpiar filtros
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Apellido</th>
                                <th>RUN</th>
                                <th>Teléfono</th>
                                <th>Email</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (personas && personas.length> 0) { %>
                                <% personas.forEach(persona=> { %>
                                    <tr class="persona-row">
                                        <td>
                                            <%= persona.id_persona || persona.id %>
                                        </td>
                                        <td>
                                            <%= persona.nombres || persona.nombre %>
                                        </td>
                                        <td>
                                            <%= persona.apellido_paterno || persona.apellido %>
                                        </td>
                                        <td>
                                            <%= persona.run || persona.cedula %>
                                        </td>
                                        <td>
                                            <%= persona.telefono || 'N/A' %>
                                        </td>
                                        <td>
                                            <%= persona.email || 'N/A' %>
                                        </td>
                                        <td>
                                            <% if(persona.activo) { %>
                                                <span class="badge bg-success">Activo</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Inactivo</span>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <a href="/personas/editar/<%= persona.id_persona || persona.id %>"
                                                class="btn btn-sm btn-outline-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/personas/eliminar/<%= persona.id_persona || persona.id %>"
                                                class="btn btn-sm btn-outline-danger" title="Eliminar"
                                                onclick="return confirm('¿Está seguro de eliminar esta persona?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="8" class="text-center text-muted">
                                                    <i class="bi bi-info-circle"></i> No hay personas registradas
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Mostrando <span id="contador">
                            <%= personas.length %>
                        </span> personas
                    </div>

                    <!-- Indicador de exportación -->
                    <div id="exportando" style="display: none;" class="text-info">
                        <i class="bi bi-hourglass-split"></i> Generando archivo Excel...
                    </div>
                </div>

            </div>
        </div>
    </main>

    <footer class="text-center text-white mt-5 py-4" style="background-color: #1e3a8a;">
        <div class="container">
            <p class="mb-1">
                &copy; 2026 Sistema de Gestión Vehicular
            </p>
            <p class="small mb-1">
                <i class="bi bi-shield-check me-1"></i>Control • Seguridad • Reportes
            </p>
            <small class="text-white-50">
                <i class="bi bi-people-fill me-1"></i> Módulo de Personas v2.0.0
            </small>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {

            // Función para filtrar la tabla
            function filtrar() {
                let nombre = $("#filtroNombre").val().toLowerCase();
                let run = $("#filtroRun").val().toLowerCase();
                let email = $("#filtroEmail").val().toLowerCase();
                let estado = $("#filtroEstado").val().toLowerCase();

                let total = 0;

                $(".persona-row").each(function () {
                    let fila = $(this);

                    let nombreCompleto = fila.find("td:eq(1)").text().toLowerCase() + " " +
                        fila.find("td:eq(2)").text().toLowerCase();
                    let runText = fila.find("td:eq(3)").text().toLowerCase();
                    let emailText = fila.find("td:eq(5)").text().toLowerCase();
                    let estadoText = fila.find("td:eq(6)").text().toLowerCase();

                    let coincideNombre = nombre === "" || nombreCompleto.includes(nombre);
                    let coincideRun = run === "" || runText.includes(run);
                    let coincideEmail = email === "" || emailText.includes(email);
                    let coincideEstado = estado === "" || estadoText.includes(estado);

                    let mostrar = coincideNombre && coincideRun && coincideEmail && coincideEstado;

                    fila.toggle(mostrar);

                    if (mostrar) total++;
                });

                $("#contador").text(total);

                // Mostrar mensaje si no hay resultados
                if (total === 0) {
                    if ($("#noResultados").length === 0) {
                        $("tbody").append('<tr id="noResultados"><td colspan="8" class="text-center text-warning"><i class="bi bi-exclamation-triangle"></i> No se encontraron resultados</td></tr>');
                    }
                } else {
                    $("#noResultados").remove();
                }
            }

            // Eventos para filtros
            $("#filtroNombre, #filtroRun, #filtroEmail").on("keyup", filtrar);
            $("#filtroEstado").on("change", filtrar);

            // Limpiar filtros
            $("#limpiarFiltros").on("click", function () {
                $("#filtroNombre").val("");
                $("#filtroRun").val("");
                $("#filtroEmail").val("");
                $("#filtroEstado").val("");
                filtrar();
            });

            // Mostrar indicador al exportar
            $("#btnExportarExcel").on("click", function () {
                $("#exportando").fadeIn();
                setTimeout(function () {
                    $("#exportando").fadeOut();
                }, 3000);
            });

        });
    </script>
</body>

</html>