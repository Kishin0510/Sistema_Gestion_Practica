<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Gestión Documental' %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="/css/Index.css">
    <style>
        :root {
            --primary: #1e3a8a;
            --primary-dark: #172554;
            --info-custom: #0d6efd;
            --info-custom-dark: #0b5ed7;
        }
        html,
        body {
            height: 100%;
            margin: 0;
        }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .content-wrapper {
            flex: 1 0 auto;
        }

        .bg-primary {
            background-color: var(--primary) !important;
        }
        .btn-primary {
            background-color: var(--primary);
            border-color: var(--primary);
        }
        .btn-primary:hover {
            background-color: var(--primary-dark);
            border-color: var(--primary-dark);
        }
        .text-primary {
            color: var(--primary) !important;
        }
        .border-primary {
            border-color: var(--primary) !important;
        }
        .card-header.bg-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
        }
        .modal-header.bg-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
        }
        .modal-header.bg-info-custom {
            background: linear-gradient(135deg, var(--info-custom) 0%, var(--info-custom-dark) 100%) !important;
            color: white;
        }
        .card.text-white,
        .card.text-white .card-body,
        .card.text-white .card-title,
        .card.text-white h2,
        .card.text-white h5,
        .card.text-white p,
        .card.text-white span {
            color: #ffffff !important;
        }
        .card.text-white h2 {
            font-weight: 700;
            font-size: 2.2rem;
        }
        .resumen-doc {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 10px;
            padding: 1rem;
        }
        .label-strong {
            font-weight: 700;
            margin-bottom: .35rem;
        }
        footer {
            flex-shrink: 0;
            width: 100%;
            background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%) !important;
            margin-top: auto;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-car me-2"></i>Gestión Vehicular
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/vehiculos">Vehículos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/documentos">Documentos</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <%
        function formatDateInput(fecha) {
            if (!fecha) return '';
            const d = new Date(fecha);
            if (isNaN(d.getTime())) return '';
            const y = d.getFullYear();
            const m = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return y + '-' + m + '-' + day;
        }

        function safeAttr(value) {
            if (value === null || value === undefined) return '';
            return String(value)
                .split('&').join('&amp;')
                .split('"').join('&quot;')
                .split('<').join('&lt;')
                .split('>').join('&gt;')
                .split('\n').join(' ')
                .split('\r').join(' ');
        }

        const puedeEliminarDocumento = usuario && ['actualizador', 'admin_cliente', 'super_admin'].includes(usuario.rol);
    %>

    <div class="content-wrapper">
        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-file-alt me-2" style="color: var(--primary);"></i>Gestión Documental</h2>
                <div>
                    <button class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#modalNuevaMantencion">
                        <i class="fas fa-tools me-2"></i>Nueva Mantención
                    </button>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoDocumento">
                        <i class="fas fa-plus me-2"></i>Nuevo Documento
                    </button>
                </div>
            </div>

            <% if (typeof success_msg !== 'undefined' && success_msg) { %>
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>
                    <%= success_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <% if (typeof error_msg !== 'undefined' && error_msg) { %>
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <%= error_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card text-white bg-primary">
                        <div class="card-body text-center">
                            <h5 class="card-title">Total Documentos</h5>
                            <h2><%= totalDocumentos || 0 %></h2>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card text-white bg-success">
                        <div class="card-body text-center">
                            <h5 class="card-title">Vigentes</h5>
                            <h2><%= documentosVigentes || 0 %></h2>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card text-white bg-warning">
                        <div class="card-body text-center">
                            <h5 class="card-title">Por Vencer</h5>
                            <h2><%= documentosPorVencer || 0 %></h2>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card text-white bg-danger">
                        <div class="card-body text-center">
                            <h5 class="card-title">Vencidos</h5>
                            <h2><%= documentosVencidos || 0 %></h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-list me-2"></i>Documentos Registrados</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="tablaDocumentos" class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Vehículo</th>
                                    <th>Tipo</th>
                                    <th>Número</th>
                                    <th>Vencimiento</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (documentos && documentos.length > 0) { %>
                                    <% for (var i = 0; i < documentos.length; i++) { 
                                        var doc = documentos[i];
                                        var fechaVenc = new Date(doc.fecha_vencimiento);
                                        var hoy = new Date();
                                        var diffDays = Math.ceil((fechaVenc - hoy) / (1000 * 60 * 60 * 24));
                                        var estadoClass = 'success';
                                        var estadoTexto = 'Vigente';

                                        if (diffDays <= 0) {
                                            estadoClass = 'danger';
                                            estadoTexto = 'Vencido';
                                        } else if (diffDays <= 7) {
                                            estadoClass = 'danger';
                                            estadoTexto = '⏳ Urgente';
                                        } else if (diffDays <= 30) {
                                            estadoClass = 'warning';
                                            estadoTexto = '⏳ Por vencer';
                                        }

                                        var vehiculoTexto = ((doc.patente || 'N/A') + ' - ' + (doc.marca || '') + ' ' + (doc.modelo || '')).trim();
                                    %>
                                        <tr>
                                            <td><%= doc.id_documento_veh %></td>
                                            <td>
                                                <strong><%= doc.patente || 'N/A' %></strong><br>
                                                <small><%= doc.marca || '' %> <%= doc.modelo || '' %></small>
                                            </td>
                                            <td><%= doc.tipo_documento_nombre %></td>
                                            <td><%= doc.numero_documento %></td>
                                            <td><%= fechaVenc.toLocaleDateString() %></td>
                                            <td>
                                                <span class="badge bg-<%= estadoClass %>">
                                                    <%= estadoTexto %>
                                                </span>
                                            </td>
                                            <td>
                                                <button
                                                    type="button"
                                                    class="btn btn-sm btn-info ver-documento"
                                                    data-id="<%= safeAttr(doc.id_documento_veh) %>"
                                                    data-idvehiculo="<%= safeAttr(doc.id_vehiculo || '') %>"
                                                    data-vehiculo="<%= safeAttr(vehiculoTexto) %>"
                                                    data-tipo="<%= safeAttr(doc.tipo_documento_nombre || '') %>"
                                                    data-numero="<%= safeAttr(doc.numero_documento || '') %>"
                                                    data-emision="<%= safeAttr(formatDateInput(doc.fecha_emision)) %>"
                                                    data-vencimiento="<%= safeAttr(formatDateInput(doc.fecha_vencimiento)) %>"
                                                    data-observaciones="<%= safeAttr(doc.observaciones || '') %>"
                                                    data-estado="<%= safeAttr(estadoTexto) %>">
                                                    <i class="fas fa-eye"></i>
                                                </button>

                                                <% if (doc.ruta_archivo) { %>
                                                    <a href="<%= doc.ruta_archivo %>" class="btn btn-sm btn-success" target="_blank">
                                                        <i class="fas fa-file-pdf"></i>
                                                    </a>
                                                <% } %>

                                                <% if (puedeEliminarDocumento) { %>
                                                    <button
                                                        type="button"
                                                        class="btn btn-sm btn-danger eliminar-documento"
                                                        data-id="<%= safeAttr(doc.id_documento_veh) %>"
                                                        data-tipo="<%= safeAttr(doc.tipo_documento_nombre || '') %>"
                                                        data-numero="<%= safeAttr(doc.numero_documento || '') %>">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-tools me-2"></i>Historial de Mantenciones</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="tablaMantenciones" class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Vehículo</th>
                                    <th>Tipo Servicio</th>
                                    <th>Kilometraje</th>
                                    <th>Horas</th>
                                    <th>Fecha</th>
                                    <th>Costo</th>
                                    <th>Taller</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof mantenciones !== 'undefined' && mantenciones.length > 0) { %>
                                    <% for (var k = 0; k < mantenciones.length; k++) { var m = mantenciones[k]; %>
                                        <tr>
                                            <td><strong><%= m.patente %></strong></td>
                                            <td><%= m.tipo_mantencion %></td>
                                            <td><%= m.kilometraje.toLocaleString() %> km</td>
                                            <td><%= m.horas ? m.horas + ' hrs' : 'N/A' %></td>
                                            <td><%= new Date(m.fecha_mantencion).toLocaleDateString() %></td>
                                            <td>$<%= m.costo_total ? m.costo_total.toLocaleString() : '0' %></td>
                                            <td><%= m.taller_proveedor || 'N/A' %></td>
                                            <td>
                                                <button class="btn btn-sm btn-warning editar-mantencion" data-id="<%= m.id_mantencion %>">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button class="btn btn-sm btn-danger eliminar-mantencion" data-id="<%= m.id_mantencion %>">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                                <% if (m.ruta_archivo) { %>
                                                    <a href="<%= m.ruta_archivo %>" class="btn btn-sm btn-outline-secondary" target="_blank">
                                                        <i class="fas fa-paperclip"></i>
                                                    </a>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalNuevaMantencion" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Registrar Mantención</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/mantenciones/registrar" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Vehículo <span class="text-danger">*</span></label>
                                <select class="form-select" name="id_vehiculo" required>
                                    <option value="">Seleccione un vehículo...</option>
                                    <% if (vehiculos && vehiculos.length > 0) { %>
                                        <% for (var j = 0; j < vehiculos.length; j++) { var v = vehiculos[j]; %>
                                            <option value="<%= v.id_vehiculo %>">
                                                <%= v.patente %> - <%= v.marca %> <%= v.modelo %>
                                            </option>
                                        <% } %>
                                    <% } %>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Tipo de Mantención</label>
                                <input type="text" class="form-control" name="tipo_mantencion" placeholder="Ej: Cambio de aceite" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Kilometraje <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" name="kilometraje" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Horas Motor</label>
                                <input type="number" class="form-control" name="horas" placeholder="Horas de operación">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Fecha Servicio <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" name="fecha_mantencion" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Costo Total</label>
                                <input type="number" step="0.01" class="form-control" name="costo">
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label">Taller / Proveedor</label>
                                <input type="text" class="form-control" name="taller">
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label">Archivo Respaldo (Opcional)</label>
                                <input type="file" class="form-control" name="archivo_mantencion">
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label">Observaciones</label>
                                <textarea class="form-control" name="observaciones" rows="2"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-success">Guardar Mantención</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalNuevoDocumento" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-file-medical me-2"></i>Registrar Nuevo Documento</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/documentos/vehiculo/registrar" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Vehículo (Patente) <span class="text-danger">*</span></label>
                                <select class="form-select" name="id_vehiculo" required>
                                    <option value="">Seleccione un vehículo...</option>
                                    <% if (typeof vehiculos !== 'undefined' && vehiculos.length > 0) { %>
                                        <% for (var j = 0; j < vehiculos.length; j++) { var v = vehiculos[j]; %>
                                            <option value="<%= v.id_vehiculo %>">
                                                <%= v.patente %> - <%= v.marca %> <%= v.modelo %>
                                            </option>
                                        <% } %>
                                    <% } %>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Tipo de Documento <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="tipo_documento_nombre" placeholder="Ej: Revisión Técnica" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Número de Documento <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="numero_documento" placeholder="Ej: PIF-123456" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Fecha de Emisión</label>
                                <input type="date" class="form-control" name="fecha_emision">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Fecha de Vencimiento <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" name="fecha_vencimiento" required>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Archivo (PDF, JPG, PNG) <span class="text-danger">*</span></label>
                                <input type="file" class="form-control" name="archivo_documento" required>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Observaciones</label>
                                <textarea class="form-control" name="observaciones" rows="3" placeholder="Detalles extra del documento..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Registrar Documento</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalVerDocumento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-info-custom">
                    <h5 class="modal-title">
                        <i class="fas fa-calendar-check me-2"></i>Modificar Fechas del Documento
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form id="formEditarFechasDocumento" method="POST">
                    <div class="modal-body">
                        <input type="hidden" name="id_documento" id="ver_doc_id">
                        <input type="hidden" name="id_vehiculo" id="ver_doc_id_vehiculo">

                        <div class="resumen-doc mb-4">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <div class="label-strong">Vehículo</div>
                                    <input type="text" id="ver_doc_vehiculo" class="form-control" readonly>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <div class="label-strong">Estado actual</div>
                                    <input type="text" id="ver_doc_estado" class="form-control" readonly>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <div class="label-strong">Tipo de documento</div>
                                    <input type="text" id="ver_doc_tipo" class="form-control" readonly>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <div class="label-strong">Número de documento</div>
                                    <input type="text" id="ver_doc_numero" class="form-control" readonly>
                                </div>

                                <div class="col-12 mb-3">
                                    <div class="label-strong">Observaciones</div>
                                    <textarea id="ver_doc_observaciones" class="form-control" rows="2" readonly></textarea>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Fecha de Emisión</label>
                                    <input type="date" class="form-control" name="fecha_emision" id="ver_doc_emision">
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Fecha de Vencimiento <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="fecha_vencimiento" id="ver_doc_vencimiento" required>
                                </div>

                                <div class="col-12 mb-3">
                                    <label class="form-label fw-bold">Motivo del cambio <span class="text-danger">*</span></label>
                                    <textarea
                                        class="form-control"
                                        name="motivo_cambio"
                                        id="ver_doc_motivo"
                                        rows="3"
                                        placeholder="Ej: Actualización del documento por nuevo vencimiento..."
                                        required></textarea>
                                </div>

                                <div class="col-12">
                                    <div class="alert alert-warning mb-0">
                                        <i class="fas fa-bell me-2"></i>
                                        Al guardar el cambio se deberá registrar una alerta para el <strong>admin_cliente</strong>.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalEditarMantencion" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Editar Mantención</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="formEditarMantencion" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <input type="hidden" name="id_mantencion" id="edit_m_id">
                        <div class="row" id="edit_m_body"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-warning">Actualizar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <footer class="text-center text-white py-4">
        <div class="container">
            <p class="mb-1">&copy; 2026 Sistema de Gestión Vehicular</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#tablaDocumentos').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                order: [[4, 'asc']]
            });

            $('#tablaMantenciones').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                order: [[4, 'desc']]
            });

            $('.editar-mantencion').on('click', function () {
                const id = $(this).data('id');
                $('#edit_m_id').val(id);
                $('#formEditarMantencion').attr('action', `/mantenciones/actualizar/${id}`);

                const modalEditar = new bootstrap.Modal(document.getElementById('modalEditarMantencion'));
                modalEditar.show();
            });

            $('.eliminar-mantencion').on('click', function () {
                const id = $(this).data('id');
                if (confirm('¿Estás seguro de eliminar este registro de mantención? Esta acción no se puede deshacer.')) {
                    window.location.href = `/mantenciones/eliminar/${id}`;
                }
            });

            $('.ver-documento').on('click', function () {
                const id = $(this).attr('data-id') || '';
                const idVehiculo = $(this).attr('data-idvehiculo') || '';
                const vehiculo = $(this).attr('data-vehiculo') || '';
                const tipo = $(this).attr('data-tipo') || '';
                const numero = $(this).attr('data-numero') || '';
                const emision = $(this).attr('data-emision') || '';
                const vencimiento = $(this).attr('data-vencimiento') || '';
                const observaciones = $(this).attr('data-observaciones') || '';
                const estado = $(this).attr('data-estado') || '';

                $('#ver_doc_id').val(id);
                $('#ver_doc_id_vehiculo').val(idVehiculo);
                $('#ver_doc_vehiculo').val(vehiculo);
                $('#ver_doc_tipo').val(tipo);
                $('#ver_doc_numero').val(numero);
                $('#ver_doc_emision').val(emision);
                $('#ver_doc_vencimiento').val(vencimiento);
                $('#ver_doc_observaciones').val(observaciones);
                $('#ver_doc_estado').val(estado);
                $('#ver_doc_motivo').val('');

                $('#formEditarFechasDocumento').attr('action', `/documentos/vehiculo/actualizar-fechas/${id}`);

                const modalDocumento = new bootstrap.Modal(document.getElementById('modalVerDocumento'));
                modalDocumento.show();
            });
            $('.eliminar-documento').on('click', function () {
                const id = $(this).data('id');
                const tipo = $(this).data('tipo') || 'documento';
                const numero = $(this).data('numero') || '';

                const mensaje = numero
                    ? `¿Estás seguro de eliminar el documento "${tipo}" N° ${numero}? Esta acción no se puede deshacer.`
                    : `¿Estás seguro de eliminar este documento? Esta acción no se puede deshacer.`;

                if (!confirm(mensaje)) return;

                fetch(`/documentos/eliminar/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(async (res) => {
                    let data = {};
                    try {
                        data = await res.json();
                    } catch (e) {}

                    if (res.ok) {
                        alert(data.message || 'Documento eliminado correctamente');
                        window.location.reload();
                    } else {
                        alert(data.error || 'No se pudo eliminar el documento');
                    }
                })
                .catch((error) => {
                    console.error('Error al eliminar documento:', error);
                    alert('Error de servidor al eliminar el documento');
                });
            });
        });
    </script>
</body>
</html>