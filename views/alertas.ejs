<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Alertas del Sistema' %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/Index.css">

    <style>
        :root {
            --primary: #1e3a8a;
            --primary-dark: #172554;
            --warning-bg: #fff3cd;
            --warning-border: #ffecb5;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .content-wrapper {
            flex: 1 0 auto;
        }

        .bg-primary-custom {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
        }

        .card-alerta {
            border-left: 5px solid #ffc107;
            transition: all 0.2s ease;
        }

        .card-alerta:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.12);
        }

        .alerta-leida {
            opacity: 0.8;
            border-left-color: #6c757d;
        }

        .stats-card h3,
        .stats-card h5 {
            color: white !important;
        }

        footer {
            margin-top: auto;
            background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%) !important;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary-custom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-car me-2"></i>Gestión Vehicular
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarAlertas">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarAlertas">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/alertas">Alertas</a>
                    </li>
                    <% if (usuario) { %>
                        <li class="nav-item">
                            <span class="nav-link">
                                <i class="fas fa-user-circle me-1"></i><%= usuario.nombre || usuario.nombre_completo || 'Usuario' %>
                            </span>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="content-wrapper">
        <div class="container mt-4">

            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                <div>
                    <h2 class="mb-1">
                        <i class="fas fa-bell text-warning me-2"></i>Alertas del Sistema
                    </h2>
                    <p class="text-muted mb-0">Notificaciones generadas por cambios y vencimientos documentales</p>
                </div>

                <div>
                    <form action="/alertas/marcar-todas" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check-double me-2"></i>Marcar todas como leídas
                        </button>
                    </form>
                </div>
            </div>

            <% if (typeof success_msg !== 'undefined' && success_msg) { %>
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>
                    <%= success_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <% if (typeof error_msg !== 'undefined' && error_msg) { %>
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <%= error_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <div class="card stats-card bg-primary-custom text-white shadow">
                        <div class="card-body text-center">
                            <h5 class="card-title">Total Alertas</h5>
                            <h3><%= totalAlertas || 0 %></h3>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card stats-card bg-danger text-white shadow">
                        <div class="card-body text-center">
                            <h5 class="card-title">No Leídas</h5>
                            <h3><%= alertasNoLeidas || 0 %></h3>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card stats-card bg-success text-white shadow">
                        <div class="card-body text-center">
                            <h5 class="card-title">Leídas</h5>
                            <h3><%= alertasLeidas || 0 %></h3>
                        </div>
                    </div>
                </div>
            </div>

            <% if (alertas && alertas.length > 0) { %>
                <div class="row">
                    <% alertas.forEach(alerta => { %>
                        <div class="col-12 mb-3">
                            <div class="card card-alerta shadow-sm <%= alerta.leido ? 'alerta-leida' : '' %>">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                        <div>
                                            <h5 class="card-title mb-2">
                                                <i class="fas fa-bell me-2 text-warning"></i>
                                                <%= alerta.tipo_alerta || 'Alerta' %>
                                            </h5>

                                            <p class="mb-2"><%= alerta.mensaje %></p>

                                            <div class="small text-muted">
                                                <div><strong>Entidad:</strong> <%= alerta.tipo_entidad %></div>
                                                <div><strong>ID Entidad:</strong> <%= alerta.id_entidad %></div>
                                                <% if (alerta.id_documento) { %>
                                                    <div><strong>ID Documento:</strong> <%= alerta.id_documento %></div>
                                                <% } %>
                                                <div><strong>Fecha:</strong> <%= new Date(alerta.fecha_generacion).toLocaleString('es-CL') %></div>
                                                <div><strong>Método:</strong> <%= alerta.metodo_envio || 'sistema' %></div>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <% if (!alerta.leido) { %>
                                                <form action="/alertas/marcar-leida/<%= alerta.id_alerta %>" method="POST">
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="fas fa-check me-1"></i>Marcar leída
                                                    </button>
                                                </form>
                                            <% } %>

                                            <form action="/alertas/eliminar/<%= alerta.id_alerta %>" method="POST" onsubmit="return confirm('¿Eliminar esta alerta?');">
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="fas fa-trash me-1"></i>Eliminar
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="card shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-bell-slash text-muted" style="font-size: 3rem;"></i>
                        <h4 class="mt-3">No hay alertas registradas</h4>
                        <p class="text-muted mb-0">Cuando se generen cambios o avisos documentales, aparecerán aquí.</p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
    <footer class="text-center text-white py-4">
        <div class="container">
            <p class="mb-1">&copy; 2026 Sistema de Gestión Vehicular</p>
            <p class="small mb-0">Alertas • Seguimiento • Notificaciones</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>